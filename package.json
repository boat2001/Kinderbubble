{
  "name": "kinderbubble-college",
  "version": "1.0.0",
  "description": "KinderBubble International School — web app + API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run frontend:build",
    "frontend:dev": "vite --config client/vite.config.js",
    "frontend:build": "vite build --config client/vite.config.js",
    "frontend:preview": "vite preview --config client/vite.config.js",
    "pages:build": "npm run frontend:build",
    "pages:deploy": "npm run pages:build && wrangler pages deploy client/dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.1.3",
    "vite": "^8.0.10",
    "wrangler": "^4.90.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
