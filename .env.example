# Server
PORT=3000
NODE_ENV=development

# Supabase
# Create these tables by running db/schema.sql in the Supabase SQL editor.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional read-only fallback for demos. Server writes require SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_ANON_KEY=your-anon-key

# CORS
# In production set this to your domain, e.g. https://kinderbubble.edu
ALLOWED_ORIGIN=*

# Admin API
# Used to protect GET /api/contact.
ADMIN_API_KEY=change-me-to-a-strong-secret

# SMTP (Email)
# Leave SMTP_HOST blank in development to log emails to console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

MAIL_FROM="KinderBubble College" <noreply@kinderbubble.edu>
ADMIN_EMAIL=admin@kinderbubble.edu
